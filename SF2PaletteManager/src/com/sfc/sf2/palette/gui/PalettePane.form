    <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton1">
      <Properties>
        <Property name="messageText" type="java.lang.String" value="&lt;html&gt;Select the palette color to edit it.&lt;br&gt;&lt;br&gt;&lt;b&gt;Advanced Controls:&lt;/b&gt;&lt;br&gt;- &lt;i&gt;Left-Drag:&lt;/i&gt; Rearrange ONLY the palette color indices. This will cause the image colors to visually change (since the image pixels are assigned a color index).&lt;br&gt;- &lt;i&gt;Right-Drag:&lt;/i&gt; Rearrange the palette color indices AND image pixels. This ensures that the image does not visually change, but its underlying pixel data will be modified to match the color index changes.&lt;/html&gt;"/>
        <Property name="text" type="java.lang.String" value=""/>
      </Properties>
    </Component>
